{
  "inlayHint.enable": false,
  "rust-analyzer.procMacro.enable": true,
  "rust-analyzer.check.command": "clippy",
  "languageserver": {
    "cmake": {
      "command": "cmake-language-server",
      "filetypes": ["cmake"],
      "rootPatterns": [
        "build/"
      ],
      "initializationOptions": {
        "buildDirectory": "build"
      }
    },
    "csharp-ls": {
      "command": "csharp-ls",
      "filetypes": ["cs"],
      "rootPatterns": ["*.csproj"]
    }
  }
}
