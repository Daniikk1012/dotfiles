#!/usr/bin/env sh
# ONLY INSTALLS HOME FILES. NO SCRIPT IS PROVIDED FOR ROOT
set -e
PREFIX=$(realpath $(dirname "$0"))
for file in .clang-format .config/fish/config.fish .config/ghostty .config/kak \
            .gradle/init.gradle .local/bin/ifmt .local/bin/sort .profile \
            .rustfmt.toml .tmux.conf .vim/vimrc
do
    echo "Linking $file..."
    test \( ! -e "$HOME/$file" \) -o \( -L "$HOME/$file" \)
    ln -sfT "$PREFIX/$file" "$HOME/$file"
done
echo 'Done!'
