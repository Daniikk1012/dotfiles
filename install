#!/usr/bin/env sh
# ONLY INSTALLS HOME FILES. NO SCRIPT IS PROVIDED FOR ROOT
set -e
PREFIX=$(realpath $(dirname "$0"))
ESCAPED_PREFIX=$(echo "$PREFIX" | sed 's/[]\/$*.^[]/\\&/g') # https://stackoverflow.com/a/2705678
find "$PREFIX" \( -type f -o -type l \) ! -path "$PREFIX/.git/*" ! -path "$PREFIX/root/*" ! -name install | sed "s/$ESCAPED_PREFIX\\///" | while read file
do
    echo "Linking $file..."
    test \( ! -e "$HOME/$file" \) -o \( -L "$HOME/$file" \)
    ln -sf "$PREFIX/$file" "$HOME/$file"
done
echo 'Done!'
